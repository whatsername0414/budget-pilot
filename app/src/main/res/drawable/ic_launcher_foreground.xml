<?xml version="1.0" encoding="utf-8"?>
<!-- Peso-glyph mark: a bold "P" stem + bowl (the bowl doubles as a compass/coin
     ring) with two horizontal crossbars evoking the ₱ sign, plus a small
     wingtip flourish for "pilot". Single solid color throughout so this same
     drawable also works unmodified as the themed-icon monochrome layer. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- Stem -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M46,34 L54,34 L54,86 L46,86 Z" />
    <!-- Bowl / compass ring (annulus, evenOdd cuts the inner hole) -->
    <path
        android:fillColor="#FFFFFF"
        android:fillType="evenOdd"
        android:pathData="
            M60,30 A14,14 0 1,1 60,58 A14,14 0 1,1 60,30 Z
            M60,37 A7,7 0 1,0 60,51 A7,7 0 1,0 60,37 Z" />
    <!-- Peso crossbars -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M38,56 L62,56 L62,60 L38,60 Z" />
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M38,66 L62,66 L62,70 L38,70 Z" />
    <!-- Wingtip flourish -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M46,86 L30,94 L46,90 Z" />
</vector>
